# Dev Container Environment Variables

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pos_db
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=pos_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=pos_password

# Kafka
KAFKA_BROKERS=kafka:29092

# MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Mailhog (for email testing)
MAILHOG_SMTP_HOST=mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_API_URL=http://mailhog:8025

# HashiCorp Vault
VAULT_ADDR=https://vault:8200
VAULT_SKIP_VERIFY=true
VAULT_ENV=development

# Application
NODE_ENV=development
GO_ENV=development

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_ENVIRONMENT=development

# API Gateway
API_GATEWAY_PORT=8080
API_GATEWAY_HOST=0.0.0.0

# Auth Service
AUTH_SERVICE_PORT=8082
AUTH_SERVICE_HOST=0.0.0.0

# Tenant Service
TENANT_SERVICE_PORT=8081
TENANT_SERVICE_HOST=0.0.0.0

# User Service
USER_SERVICE_PORT=8083
USER_SERVICE_HOST=0.0.0.0

# Order Service
ORDER_SERVICE_PORT=8084
ORDER_SERVICE_HOST=0.0.0.0

# Product Service
PRODUCT_SERVICE_PORT=8085
PRODUCT_SERVICE_HOST=0.0.0.0

# Notification Service
NOTIFICATION_SERVICE_PORT=8086
NOTIFICATION_SERVICE_HOST=0.0.0.0

# Audit Service
AUDIT_SERVICE_PORT=8087
AUDIT_SERVICE_HOST=0.0.0.0

# External Services (use sandbox credentials for development)
MIDTRANS_SERVER_KEY=YOUR_MIDTRANS_SANDBOX_SERVER_KEY
MIDTRANS_CLIENT_KEY=YOUR_MIDTRANS_SANDBOX_CLIENT_KEY
MIDTRANS_ENVIRONMENT=sandbox

# Google Maps
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# JWT
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRATION=24h

# Encryption
ENCRYPTION_KEY=dev-encryption-key-32-chars-123456
